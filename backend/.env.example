# Copy to .env and adjust for your local environment. Do not commit .env.
SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── AI agent (Anthropic) ──
# Leave ANTHROPIC_API_KEY blank to run the app without the assistant: chat
# returns 503 and the scheduler idles, but todos/auth keep working.
ANTHROPIC_API_KEY=
# A current Claude model used for tool-use chat.
ANTHROPIC_MODEL=claude-opus-4-8
# Optional: switched to after repeated 529/overloaded errors.
ANTHROPIC_FALLBACK_MODEL=claude-sonnet-4-6
# Secondary (cheaper/faster) model for the per-turn memory-retrieval pass.
ANTHROPIC_SECONDARY_MODEL=claude-haiku-4-5
# At/below this many stored facts, inject all and skip the retrieval LLM call.
AGENT_MEMORY_RETRIEVAL_THRESHOLD=5
# Scheduler poll cadence in seconds (cron matches at minute granularity).
AGENT_SCHEDULER_INTERVAL=30
# Max tool-loop turns per chat/cron turn (runaway-loop guard).
AGENT_MAX_TURNS=8
